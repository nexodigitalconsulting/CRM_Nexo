# ============================================
# CRM Nexo v2.0 — Variables de entorno
# cp .env.example .env  y rellenar con valores
# ============================================

# ----- Base de datos (PostgreSQL) -----
DATABASE_URL="postgresql://user:password@host:5432/Crm_Nexo"

# ----- Better Auth -----
# Generar con: openssl rand -hex 32
BETTER_AUTH_SECRET="cambia-esto-por-secreto-de-32-caracteres-minimo"
BETTER_AUTH_URL="https://tudominio.com"

# ----- Next.js (public — se expone al browser) -----
NEXT_PUBLIC_APP_URL="https://tudominio.com"

# ----- Cloudflare R2 (almacenamiento de archivos) -----
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="crm-nexo-assets"
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# ----- Email (SMTP) -----
SMTP_HOST="smtp.tu-proveedor.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@tudominio.com"

# CRON: secret para llamar /api/cron/notifications desde un scheduler externo
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=""

# ----- n8n (trigger de flujos) -----
# Opción A — webhook: pega la URL del webhook directamente en el campo "Webhook URL o ID" del flujo
# Opción B — REST API: rellena estas variables y usa el ID del workflow en n8n
N8N_BASE_URL=""        # Ej: http://n8n:5678 o https://n8n.tudominio.com
N8N_API_KEY=""         # Ajustes → API → Create API Key en n8n
