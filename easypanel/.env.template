# ============================================
# CRM Stack - Variables de Entorno
# ============================================
# Copia este archivo como .env y configura los valores
# cp .env.template .env

# ============================================
# CONFIGURACIÓN DEL PROYECTO
# ============================================
PROJECT_NAME=mi_crm
ORGANIZATION_NAME=Mi Empresa

# ============================================
# URLs PÚBLICAS (CAMBIAR POR TU DOMINIO)
# ============================================
# Dominio principal de la API de Supabase
SUPABASE_PUBLIC_URL=https://api.tudominio.com
API_EXTERNAL_URL=https://api.tudominio.com

# URL del frontend CRM
SITE_URL=https://crm.tudominio.com

# URLs adicionales permitidas para OAuth
ADDITIONAL_REDIRECT_URLS=https://crm.tudominio.com/**

# URL de webhooks de n8n
N8N_WEBHOOK_URL=https://n8n.tudominio.com
N8N_HOST=n8n.tudominio.com

# ============================================
# PUERTOS (solo si no usas proxy inverso)
# ============================================
POSTGRES_PORT=5432
STUDIO_PORT=3000
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
N8N_PORT=5678
CRM_PORT=80

# ============================================
# BASE DE DATOS
# ============================================
# ⚠️ IMPORTANTE: Cambia esta contraseña!
POSTGRES_PASSWORD=tu_password_super_seguro_aqui
POSTGRES_USER=postgres
POSTGRES_DB=postgres

# ============================================
# JWT & SEGURIDAD
# ============================================
# ⚠️ IMPORTANTE: Genera un nuevo secret!
# Puedes usar: openssl rand -base64 32
JWT_SECRET=super-secret-jwt-key-with-at-least-32-characters-long
JWT_EXP=3600

# Clave secreta para Realtime
# Genera con: openssl rand -base64 64
SECRET_KEY_BASE=ChangeThisToAVeryLongSecretKeyAtLeast64Characters

# Clave de encriptación para n8n
# Genera con: openssl rand -hex 32
N8N_ENCRYPTION_KEY=your_n8n_encryption_key_here

# ============================================
# CLAVES SUPABASE
# ============================================
# Genera estas claves en: https://supabase.com/docs/guides/self-hosting#api-keys
# O usa el script: scripts/generate-keys.sh

